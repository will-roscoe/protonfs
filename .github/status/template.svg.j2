<svg
xmlns="http://www.w3.org/2000/svg"
viewBox="0 0 900 420"
width="100%"
>

<style>

/**
:root {
    color-scheme: light dark;
}

svg {
    font-family:
        
        ;
}




@media (prefers-color-scheme: dark) {
    .background {
        fill:#0d1117;
        stroke:#30363d;
    }

    .text {
        fill:#f0f6fc;
    }

    .muted {
        fill:#8b949e;
    }

    .card {
        fill:#161b22;
        stroke:#30363d;
    }
}
**/
svg {
    font-family: var(--fontStack-sansSerif,-apple-system, BlinkMacSystemFont, "Segoe UI", "Noto Sans", Helvetica, Arial, sans-serif, "Apple Color Emoji", "Segoe UI Emoji"),-apple-system,
        BlinkMacSystemFont,"Segoe UI",sans-serif;
}
.background {
    fill:var(--bgColor-default, #0d1117);
    stroke:#d0d7de;
}
.text {
    fill:var(--fgColor-default,var(--color-fg-default,#f6f8fa));
    font-weight: var(--base-text-weight-normal,400);
    
}

.muted {
    fill:var(--color-prettylights-syntax-comment,#656d76);
}

.card {
    fill:var(--bgColor-muted,var(--color-canvas-subtle,#151b23));
    
    
}

.in-card { font-family: var(--fontStack-monospace,ui-monospace, SFMono-Regular, SF Mono, Menlo, Consolas, Liberation Mono, monospace);
    }

.title {
    font-size: 2em;
    font-weight: var(--base-text-weight-semibold,600);
}

.subtitle {
    font-size:16px;
}

.label {
    font-size:12px;
    font-weight:600;
    letter-spacing:0.08em;
}

.value {
    font-size:22px;
    font-weight:500;
    font-family: var(--fontStack-sansSerif,-apple-system, BlinkMacSystemFont, "Segoe UI", "Noto Sans", Helvetica, Arial, sans-serif, "Apple Color Emoji", "Segoe UI Emoji"),-apple-system,
        BlinkMacSystemFont,"Segoe UI",sans-serif;
}

.small {
    font-size:13px;
}

.link {
    fill: var(--fgColor-accent,var(--color-accent-fg, #0969da));
    text-underline-offset: .2rem;
    text-decoration: underline;
}

.pass {
    fill:var(--bgColor-success-emphasis,#1a7f37);
}

.fail {
    fill:var(--bgColor-danger-emphasis,#cf222e);
}

.warn {
    fill:var(--bgColor-attention-emphasis,#9a6700);
}

</style>


<rect
    class="background"
    x="1"
    y="1"
    width="898"
    height="418"
    rx="14"
/>


<!-- Header -->
<image
x="35"
y="20"
width="80"
height="80"
href="{{ logo_href }}"
/>
<text
    class="title text"
    x="130"
    y="55"
>
{{ project.name }}
</text>


<text
    class="subtitle muted"
    x="130"
    y="90"
>
{{ project.description }}
</text>


<text
    class="value text"
    x="820"
    y="55"
    text-anchor="end"
>
v{{ project.version }}
</text>


<!-- Links -->

{% macro link(text, url, x, anc) %}
<a href="{{ url }}">
<text
    class="link"
    x="{{ x }}"
    y="120"
    text-anchor="{{ anc }}"
>
{{ text }}
</text>
</a>
{% endmacro %}


{{ link("PyPI", links.pypi, 130, "start") }}
{{ link("Documentation", links.docs, 260, "middle") }}
{{ link("Repository", links.github, 430, "end") }}


<!-- Section title -->

<text
class="label muted"
x="35"
y="165"
>
QUALITY
</text>


<!-- Metric cards -->

{% macro card(x, title, value, detail,stat) %}

<rect
class="card"
x="{{ x }}"
y="185"
width="190"
height="90"
rx="10"
/>

<text
class="label in-card muted {{ stat }}"
x="{{ x + 15 }}"
y="210"
>
{{ title }}
</text>

<text
class="value in-card text"
x="{{ x + 15 }}"
y="242"
>
{{ value }}
</text>

<text
class="small in-card muted"
x="{{ x + 15 }}"
y="262"
>
{{ detail }}
</text>

{% endmacro %}


{{ card(
    35,
    "TESTS",
    "✓ " ~ tests.passed,
    tests.failed ~ " failed · " ~ tests.skipped ~ " skipped",
    "pass" if tests.failed == 0 else "fail"
) }}


{{ card(
    245,
    "COVERAGE",
    coverage ~ "%",
    "line coverage",
    "pass" if coverage > 80 else "warn" if coverage > 60 else "fail"

) }}


{{ card(
    455,
    "RUFF",
    "✓ Clean" if ruff.status == "passing" else "✗ Failed",
    "lint status",
    "pass" if ruff.status == "passing" else "fail"
) }}


{{ card(
    665,
    "DOCS",
    docs.coverage ~ "%",
    "documented",
    "pass" if docs.coverage > 80 else "warn" if docs.coverage > 60 else "fail"
) }}


<!-- Python -->

<text
class="label muted"
x="35"
y="325"
>
PYTHON SUPPORT
</text>


{% for py in python %}

{% set x = 45 + loop.index0 * 50 %}

<text
class="small text"
x="{{x}}"
y="355" 
dominant-baseline="middle" 
text-anchor="middle"
>
{{py.version}}
</text>

<circle
cx="{{x}}"
cy="380"
r="8"
class="{{'pass' if py.status == 'passing' else 'fail'}}"
/>

{% endfor %}


<!-- Build matrix -->


<text
class="label muted"
x="400"
y="325"
>
<!-- 35,435 -->
BUILDS
</text>


<text
class="small muted"
x="400"
y="370" 

>
x86_64
</text>

<text
class="small muted"
x="400"
y="390" 

>
ARM64
</text>


{% for os, archs in builds.items() %}

{% set x = 480 + loop.index0 * 50 %}

<text
class="small text"
x="{{x}}"
y="350"
text-anchor="middle"
>
{{os}}
</text>

{% for arch,status in archs.items() %}

{% set y = 370 if arch == "x86_64" else 390 %}

<circle
cx="{{x}}"
cy="{{y-5}}"
r="8"
class="{{'pass' if status == 'passing' else 'fail'}}"
/>

{% endfor %}

{% endfor %}


</svg>